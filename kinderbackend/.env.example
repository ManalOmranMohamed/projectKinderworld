# ===============================
# Environment & Runtime
# ===============================
# One of: development | test | production
ENVIRONMENT=development

# Optional file path for application logs (leave empty for stdout-only logs)
APP_LOG_FILE=
# Logging level: DEBUG | INFO | WARNING | ERROR
APP_LOG_LEVEL=INFO

# Local/dev convenience only. Keep false in production.
SKIP_SCHEMA_VERIFY=false
# Optional: if true, app startup will run `alembic upgrade head` automatically.
# Recommended false in production deployments; run migrations in release pipeline.
AUTO_RUN_MIGRATIONS=false

# ===============================
# Database
# ===============================
# For local dev, you can leave this empty to use sqlite:///kinder.db fallback.
DATABASE_URL=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800

# ===============================
# JWT / Auth Secrets
# ===============================
# Preferred active signing secret.
KINDER_JWT_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET

# Legacy compatibility variables (optional).
# Keep empty unless you explicitly need old naming compatibility.
JWT_SECRET_KEY=
SECRET_KEY=

# JWT signing algorithm (HS256 by default).
JWT_ALGORITHM=HS256

# Optional key identifier for the active JWT secret.
JWT_ACTIVE_KID=

# Optional comma-separated previous JWT secrets used only for token verification.
# This prepares staged secret rotation (verify old tokens, sign new with KINDER_JWT_SECRET).
# Example: JWT_PREVIOUS_SECRETS=old_secret_v1,old_secret_v0
JWT_PREVIOUS_SECRETS=

# ===============================
# Email Domain Policy (optional)
# ===============================
# Leave unset to accept any valid email domain.
EMAIL_DOMAIN_ALLOWLIST=
EMAIL_DOMAIN_DENYLIST=

# ===============================
# Child Auth Hardening (optional)
# ===============================
CHILD_AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
CHILD_AUTH_RATE_LIMIT_WINDOW_SECONDS=300
CHILD_AUTH_SUSPICIOUS_THRESHOLD=3
CHILD_SESSION_TTL_MINUTES=120
CHILD_AUTH_DEVICE_BINDING_ENABLED=false
CHILD_AUTH_REQUIRE_DEVICE_ID=false

# ===============================
# Analytics Lifecycle (optional)
# ===============================
# Retention window for raw tracking records before archival.
ANALYTICS_RETENTION_DAYS=365
# Retention window for daily summary rows before archival.
ANALYTICS_SUMMARY_RETENTION_DAYS=1825

# ===============================
# Admin Seed (DEV/TEST ONLY)
# ===============================
ENABLE_ADMIN_SEED_ENDPOINT=false
ADMIN_SEED_SECRET=CHANGE_ME_DEV_ONLY
ADMIN_SEED_PASSWORD=CHANGE_ME_DEV_ONLY
ADMIN_SEED_EMAIL=change-me@example.invalid
ADMIN_SEED_NAME=DEV ONLY ADMIN

# ===============================
# Admin Auth Hardening (optional)
# ===============================
# Temporary lock duration after repeated failed admin logins.
ADMIN_AUTH_MAX_FAILED_ATTEMPTS=5
ADMIN_AUTH_LOCKOUT_MINUTES=15
ADMIN_SUSPICIOUS_FAILED_THRESHOLD=3

# If true, sensitive admin write actions require:
# X-Admin-Confirm: CONFIRM
# X-Admin-Confirm-Action: <action_name>
ADMIN_SENSITIVE_CONFIRMATION_REQUIRED=false

# ===============================
# Test Guidance (do not commit real test secrets)
# ===============================
# In tests, set ENVIRONMENT=test and provide a dedicated test JWT secret.
# Example:
# ENVIRONMENT=test
# KINDER_JWT_SECRET=TEST_ONLY_SECRET
